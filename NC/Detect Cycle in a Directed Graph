#include <bits/stdc++.h>
using namespace std;

class Solution {
  private:
  bool dfs(vector<vector<int>>& adjMat, vector<int>& vis, vector<int>& dfsStack, int vertex) {
    vis[vertex] = 1;
    dfsStack[vertex] = 1;

    for (auto neighbor : adjMat[vertex]) {
      if (!vis[neighbor]) {
        if (dfs(adjMat, vis, dfsStack, neighbor)) return true;
      } 
      else if (dfsStack[neighbor]) {
        return true;
      }
    }

    dfsStack[vertex] = 0;
    return false;
  }

  public:
  bool detectCycleDirectedGraph(vector<vector<int>>& adjMat, int v) {
    vector<int> visited(v, 0);
    vector<int> dfsStack(v, 0);

    for (int i = 0; i < v; i++) {
      if (!visited[i]) {
        if (dfs(adjMat, visited, dfsStack, i)) return true;
      }
    }
    return false;
  }
};

int main() {
  vector<pair<int, int>> edges = {{0, 1}, {1, 2}, {2, 3}, {3, 1}};
  int vertices = 4;
  vector<vector<int>> adjMat(vertices);

  for (auto itr : edges) {
    int u = itr.first;
    int v = itr.second;
    adjMat[u].push_back(v);
  }

  Solution obj;
  if (obj.detectCycleDirectedGraph(adjMat, vertices)) cout << "yes" << endl;
  else cout << "no" << endl;

  return 0;
}
